# ============================================================================
# Relay — environment variables
# Copy this file to `.env.local` and fill in the values.
#
# Minimum to run for real:
#   AUTH_SECRET, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET   (login)
#   DATABASE_URL, TOKEN_ENCRYPTION_KEY                    (tools + persistence)
#   at least one AI provider key                          (the agent)
# ============================================================================

# ---- Auth.js (NextAuth v5) -------------------------------------------------
# Required. Generate with: openssl rand -base64 32
AUTH_SECRET=
# Base URL of the app. Auth.js infers this in most cases; set explicitly in prod.
NEXTAUTH_URL=http://localhost:3000

# ---- Google OAuth (login + Gmail/Drive/Docs/Calendar tools) ----------------
# Create an OAuth 2.0 Client at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs (add ALL of these):
#   http://localhost:3000/api/auth/callback/google      (login)
#   http://localhost:3000/api/tools/gmail/callback       (connect Gmail)
#   http://localhost:3000/api/tools/drive/callback       (connect Drive)
#   http://localhost:3000/api/tools/docs/callback        (connect Docs)
#   http://localhost:3000/api/tools/calendar/callback    (connect Calendar)
# In production, swap http://localhost:3000 for your deployed origin.
# Also enable the Gmail, Drive, Docs, and Calendar APIs in the Google project.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Database (Neon / any Postgres) ----------------------------------------
# If empty, the app falls back to an in-memory demo store (data is not persisted).
# Neon: https://neon.tech  ->  postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# ---- Token encryption ------------------------------------------------------
# 32-byte key (base64 or hex) used to encrypt stored OAuth tokens at rest.
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# ---- AI providers (set any subset; the UI shows which models are available)-
# Claude (Anthropic)
ANTHROPIC_API_KEY=
# OpenAI
OPENAI_API_KEY=
# Google Gemini (Generative Language API)
GOOGLE_GENERATIVE_AI_API_KEY=

# Open-weight models via OpenRouter — https://openrouter.ai/keys
# Unlocks Hermes 3, Llama 3.3, Qwen 2.5, DeepSeek V3, Mistral Large, ...
OPENROUTER_API_KEY=

# Open-weight models via Groq (ultra-fast) — https://console.groq.com/keys
# Unlocks Llama 3.3 70B, Llama 3.1 8B, DeepSeek R1 Distill, Gemma2, ...
GROQ_API_KEY=

# Optional: any other OpenAI-compatible gateway (Together, Fireworks, custom).
# NO Ollama / local hosting — this app is built for cloud deploy.
OPENSOURCE_BASE_URL=
OPENSOURCE_API_KEY=
# Comma-separated native model ids exposed from that gateway, e.g.
# "meta-llama/Llama-3.3-70B-Instruct-Turbo,Qwen/Qwen2.5-72B-Instruct-Turbo"
OPENSOURCE_MODELS=

# Default model id the agent uses when the user hasn't picked one.
# e.g. "claude-opus-4-8", "gpt-4o", "groq/llama-3.3-70b", "or/hermes-3-70b"
DEFAULT_MODEL=claude-opus-4-8

# ---- Workflow scheduler ----------------------------------------------------
# Bearer token protecting the scheduler tick endpoint (GET /api/cron).
# Generate with: openssl rand -base64 32
# On Vercel, set this and the included vercel.json cron will call /api/cron every
# minute with this token automatically. Self-hosting: point a system crontab at
#   curl -H "Authorization: Bearer $CRON_SECRET" https://your-host/api/cron
# If unset, /api/cron refuses to run (no unsecured scheduling).
CRON_SECRET=

# ---- Notion (Notion tools) -------------------------------------------------
# Public OAuth integration from https://www.notion.so/my-integrations
# Redirect URI: http://localhost:3000/api/tools/notion/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
