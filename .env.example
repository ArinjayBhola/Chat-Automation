# ============================================================================
# auto-chat environment variables
# Copy this file to `.env.local` and fill in what you need.
#
# DEMO MODE: the app runs with ZERO external credentials. Leave everything
# blank and click "Try Demo" on the sign-in page. The variables below only
# unlock real integrations (Google login, real tools, persistence, live AI).
# ============================================================================

# ---- Auth.js (NextAuth v5) -------------------------------------------------
# Required for real (non-demo) auth. Generate with: openssl rand -base64 32
AUTH_SECRET=
# Base URL of the app. Auth.js infers this in most cases; set explicitly in prod.
NEXTAUTH_URL=http://localhost:3000

# ---- Google OAuth (login + Gmail/Drive/Docs/Calendar tools) ----------------
# Create an OAuth 2.0 Client at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs (add ALL of these):
#   http://localhost:3000/api/auth/callback/google      (login)
#   http://localhost:3000/api/tools/gmail/callback       (connect Gmail)
#   http://localhost:3000/api/tools/drive/callback       (connect Drive)
#   http://localhost:3000/api/tools/docs/callback        (connect Docs)
#   http://localhost:3000/api/tools/calendar/callback    (connect Calendar)
# In production, swap http://localhost:3000 for your deployed origin.
# Also enable the Gmail, Drive, Docs, and Calendar APIs in the Google project.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Database (Neon / any Postgres) ----------------------------------------
# If empty, the app falls back to an in-memory demo store (data is not persisted).
# Neon: https://neon.tech  ->  postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# ---- Token encryption ------------------------------------------------------
# 32-byte key (base64 or hex) used to encrypt stored OAuth tokens at rest.
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# ---- AI providers (any subset; the UI lets you pick an available model) ----
# Claude (Anthropic)
ANTHROPIC_API_KEY=
# OpenAI
OPENAI_API_KEY=
# Google Gemini (Generative Language API)
GOOGLE_GENERATIVE_AI_API_KEY=
# Open-source models via an OpenAI-compatible cloud gateway
# (e.g. OpenRouter, Groq, Together, Fireworks). NO Ollama / local hosting.
OPENSOURCE_BASE_URL=
OPENSOURCE_API_KEY=
# Comma-separated model ids exposed for the open-source gateway, e.g.
# "meta-llama/llama-3.3-70b-instruct,qwen/qwen-2.5-72b-instruct"
OPENSOURCE_MODELS=

# Default model id the agent uses when the user hasn't picked one.
# e.g. "claude-opus-4-8", "gpt-4o", "gemini-2.0-flash"
DEFAULT_MODEL=claude-opus-4-8

# ---- Notion (Notion tools) -------------------------------------------------
# Public OAuth integration from https://www.notion.so/my-integrations
# Redirect URI: http://localhost:3000/api/tools/notion/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
